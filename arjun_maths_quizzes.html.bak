    { q:"Vertically opposite angles are equal.", type:"tf", answer:true, explain:"When two lines cross, opposite angles are equal ✓" },
    { q:"Corresponding (F) angles between parallel lines are equal.", type:"tf", answer:true, explain:"F-angles are in matching positions and are equal ✓" },
    { q:"Area of a parallelogram with base 9 cm and height 6 cm = ?", type:"mcq", options:["54 cm²","27 cm²","30 cm²","15 cm²"], answer:0, explain:"b×h=9×6=54 cm²." },
    { q:"If one co-interior angle is 65°, the other is 115°.", type:"tf", answer:true, explain:"Co-interior angles sum to 180°. 180−65=115 ✓" },
