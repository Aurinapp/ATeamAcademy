// ============================================================
// STATE
// ============================================================
let currentTopicIdx = 0;
let currentQuestions = [];
let currentQIdx = 0;
let quizAnswered = false;
let quizResults = [];
let testAnswers = {};
let testSubmitted = false;

const topicMeta = [
  { title:"🔢 Number", desc:"Primes, fractions, decimals, percentages, indices" },
  { title:"🔣 Algebra", desc:"Expressions, equations, sequences, straight-line graphs" },
  { title:"📐 Geometry & Measures", desc:"Angles, area, volume, transformations" },
  { title:"⚖️ Ratio & Proportion", desc:"Ratios, proportion, speed/distance/time" },
  { title:"📊 Statistics & Probability", desc:"Averages, data, graphs, probability" }
];

// ============================================================
// NAVIGATION
// ============================================================
function showScreen(id) {
  document.querySelectorAll('.screen').forEach(s=>s.classList.remove('active'));
  document.getElementById(id).classList.add('active');
}

function showHome() {
  showScreen('screenHome');
  document.querySelectorAll('.topic-btn').forEach(b=>b.classList.remove('active'));
}

// ============================================================
// QUIZ
// ============================================================
function startQuiz(topicIdx) {
  currentTopicIdx = topicIdx;
  currentQuestions = [...quizData[topicIdx]].sort(()=>Math.random()-0.5);
  currentQIdx = 0;
  quizAnswered = false;
  quizResults = [];

  document.getElementById('quizTopicTitle').textContent = topicMeta[topicIdx].title;
  document.getElementById('quizTopicDesc').textContent = topicMeta[topicIdx].desc;

  document.querySelectorAll('.topic-btn').forEach(b=>b.classList.remove('active'));
  const btn = document.getElementById('topicBtn'+topicIdx);
  if (btn) btn.classList.add('active');

  showScreen('screenQuiz');
  renderQuestion();
}

function renderQuestion() {
  const total = currentQuestions.length;
  const q = currentQuestions[currentQIdx];
  quizAnswered = false;

  document.getElementById('questionCounter').textContent = 'Question '+(currentQIdx+1)+' of '+total;
  document.getElementById('questionText').textContent = q.q;
  document.getElementById('quizProgressFill').style.width = ((currentQIdx/total)*100)+'%';

  const fb = document.getElementById('feedbackBox');
  fb.className = 'feedback-box';
  fb.innerHTML = '';
  document.getElementById('nextBtn').style.display = 'none';

  const area = document.getElementById('answerArea');
  area.innerHTML = '';

  if (q.type === 'mcq') {
    const opts = document.createElement('div');
    opts.className = 'options';
    q.options.forEach((opt, i) => {
      const btn = document.createElement('button');
      btn.className = 'option-btn';
      btn.innerHTML = '<span class="opt-letter">'+String.fromCharCode(65+i)+'</span>'+opt;
      btn.onclick = () => answerMcq(i, q);
      opts.appendChild(btn);
    });
    area.appendChild(opts);
  } else {
    const row = document.createElement('div');
    row.className = 'tf-row';
    const tBtn = document.createElement('button');
    tBtn.className = 'tf-btn true-btn';
    tBtn.textContent = '✓ True';
    tBtn.onclick = () => answerTf(true, q);
    const fBtn = document.createElement('button');
    fBtn.className = 'tf-btn false-btn';
    fBtn.textContent = '✗ False';
    fBtn.onclick = () => answerTf(false, q);
    row.appendChild(tBtn); row.appendChild(fBtn);
    area.appendChild(row);
  }
}

function answerMcq(selected, q) {
  if (quizAnswered) return;
  quizAnswered = true;
  const correct = selected === q.answer;
  quizResults.push({ q:q.q, correct, yourAnswer:q.options[selected], modelAnswer:q.options[q.answer] });

  document.querySelectorAll('.option-btn').forEach((b,i) => {
    b.disabled = true;
    if (i === q.answer) b.classList.add('correct-ans');
    else if (i === selected && !correct) b.classList.add('wrong-ans');
  });
  showFeedback(correct, q.explain);
}

function answerTf(selected, q) {
  if (quizAnswered) return;
  quizAnswered = true;
  const correct = selected === q.answer;
  quizResults.push({ q:q.q, correct, yourAnswer:selected?'True':'False', modelAnswer:q.answer?'True':'False' });

  document.querySelectorAll('.tf-btn').forEach(b => {
    b.disabled = true;
    const isTrueBtn = b.classList.contains('true-btn');
    if (isTrueBtn === q.answer) b.classList.add('correct-ans');
    else if (isTrueBtn === selected && !correct) b.classList.add('wrong-ans');
  });
  showFeedback(correct, q.explain);
}

function showFeedback(correct, explain) {
  const fb = document.getElementById('feedbackBox');
  fb.className = 'feedback-box show '+(correct?'correct':'incorrect');
  fb.innerHTML = '<div class="fb-title">'+(correct?'✅ Correct!':'❌ Incorrect')+'</div><div class="fb-explain">'+explain+'</div>';
  document.getElementById('nextBtn').style.display = '';
}

function nextQuestion() {
  currentQIdx++;
  if (currentQIdx >= currentQuestions.length) showQuizResult();
  else renderQuestion();
}

function showQuizResult() {
  const total = quizResults.length;
  const correct = quizResults.filter(r=>r.correct).length;
  const pct = Math.round(correct/total*100);

  document.getElementById('resultScore').textContent = pct+'%';
  document.getElementById('resultLabel').textContent = correct+' out of '+total+' correct';
  document.getElementById('resultEmoji').textContent = pct>=80?'🎉':pct>=60?'😊':'😬';
  document.getElementById('resultMessage').textContent = pct>=80?'Brilliant work, Arjun!':pct>=60?'Good effort — keep at it!':'More revision needed!';

  document.getElementById('quiz-retry-nudge').style.display = pct<80?'':'none';
  document.getElementById('quiz-pass-actions').style.display = pct>=80?'':'none';
  document.getElementById('reviewSection').style.display = 'none';
  showScreen('screenResult');
}

function retryQuiz() { startQuiz(currentTopicIdx); }

function showReview() {
  const section = document.getElementById('reviewSection');
  section.style.display = '';
  const list = document.getElementById('reviewList');
  list.innerHTML = '';
  quizResults.forEach(r => {
    const li = document.createElement('li');
    li.className = 'review-item '+(r.correct?'correct':'incorrect');
    li.innerHTML = `<div class="review-q">${r.correct?'✅':'❌'} ${r.q}</div>
      <div class="review-answer">
        <div class="your">Your answer: <span>${r.yourAnswer}</span></div>
        <div class="model">Correct: <span>${r.modelAnswer}</span></div>
      </div>`;
    list.appendChild(li);
  });
  section.scrollIntoView({ behavior:'smooth' });
}

// ============================================================
// TEST
// ============================================================
function startTest() {
  testAnswers = {};
  testSubmitted = false;

  document.querySelectorAll('.topic-btn').forEach(b=>b.classList.remove('active'));
  const btn = document.getElementById('topicBtnTest');
  if (btn) btn.classList.add('active');

  document.getElementById('submitBtn').disabled = false;
  document.getElementById('testReviewSection').style.display = 'none';

  const body = document.getElementById('test-body');
  body.innerHTML = '';

  testData.forEach((q, i) => {
    const block = document.createElement('div');
    block.className = 'test-question-block';

    let inputHtml = '';
    if (q.type === 'mcq') {
      inputHtml = '<div class="test-options">'+q.options.map((opt,j)=>
        `<div class="test-option" id="to_${i}_${j}" onclick="selectTestOption(${i},${j})"><span class="test-opt-letter">${String.fromCharCode(65+j)}</span>${opt}</div>`
      ).join('')+'</div>';
    } else {
      inputHtml = `<div class="test-tf-row">
        <button class="test-tf-btn" id="ttf_${i}_true" onclick="selectTestTf(${i},true)">✓ True</button>
        <button class="test-tf-btn" id="ttf_${i}_false" onclick="selectTestTf(${i},false)">✗ False</button>
      </div>`;
    }

    block.innerHTML = `<div class="test-q-num">Question ${i+1} of 50</div>
      <div class="test-q-text">${q.q}</div>${inputHtml}`;
    body.appendChild(block);
  });

  showScreen('screenTest');
}

function selectTestOption(qIdx, optIdx) {
  if (testSubmitted) return;
  testAnswers[qIdx] = optIdx;
  document.querySelectorAll(`[id^="to_${qIdx}_"]`).forEach((el,i)=>el.classList.toggle('selected', i===optIdx));
}

function selectTestTf(qIdx, value) {
  if (testSubmitted) return;
  testAnswers[qIdx] = value;
  document.getElementById(`ttf_${qIdx}_true`).classList.toggle('selected', value===true);
  document.getElementById(`ttf_${qIdx}_false`).classList.toggle('selected', value===false);
}

function submitTest() {
  const unanswered = testData.filter((_,i)=>testAnswers[i]===undefined).length;
  if (unanswered > 0 && !confirm(`You have ${unanswered} unanswered question(s). Submit anyway?`)) return;

  testSubmitted = true;
  document.getElementById('submitBtn').disabled = true;

  let correct = 0;
  testData.forEach((q,i) => {
    if (testAnswers[i] === undefined) return;
    const isCorrect = testAnswers[i] === q.answer;
    if (isCorrect) correct++;

    if (q.type === 'mcq') {
      document.querySelectorAll(`[id^="to_${i}_"]`).forEach((el,j) => {
        el.classList.add('disabled'); el.classList.remove('selected');
        if (j===q.answer) el.classList.add('correct-ans');
        else if (j===testAnswers[i] && !isCorrect) el.classList.add('wrong-ans');
      });
    } else {
      const tBtn = document.getElementById(`ttf_${i}_true`);
      const fBtn = document.getElementById(`ttf_${i}_false`);
      tBtn.classList.remove('selected'); fBtn.classList.remove('selected');
      (q.answer?tBtn:fBtn).classList.add('correct-ans');
      if (testAnswers[i]!==undefined && testAnswers[i]!==q.answer)
        (testAnswers[i]?tBtn:fBtn).classList.add('wrong-ans');
    }
  });

  const pct = Math.round(correct/50*100);
  const answered = Object.keys(testAnswers).length;
  document.getElementById('testResultScore').textContent = pct+'%';
  document.getElementById('tcCorrect').textContent = correct;
  document.getElementById('tcIncorrect').textContent = answered-correct;
  document.getElementById('tcPercent').textContent = pct+'%';
  document.getElementById('testResultEmoji').textContent = pct>=80?'🏆':pct>=60?'📚':'😬';
  document.getElementById('testResultMsg').textContent = pct>=80?'Brilliant — you passed the test, Arjun!':pct>=60?'Good effort — nearly there!':'More revision needed!';
  document.getElementById('test-retry-nudge').style.display = pct<80?'':'none';
  showScreen('screenTestResult');
}

function showTestReview() {
  const section = document.getElementById('testReviewSection');
  section.style.display = '';
  const list = document.getElementById('testReviewList');
  list.innerHTML = '';
  testData.forEach((q,i) => {
    const userAns = testAnswers[i];
    if (userAns===undefined) return;
    const correct = userAns===q.answer;
    const yourTxt = q.type==='mcq'?q.options[userAns]:(userAns?'True':'False');
    const modelTxt = q.type==='mcq'?q.options[q.answer]:(q.answer?'True':'False');
    const li = document.createElement('li');
    li.className = 'review-item '+(correct?'correct':'incorrect');
    li.innerHTML = `<div class="review-q">${correct?'✅':'❌'} Q${i+1}: ${q.q}</div>
      <div class="review-answer">
        <div class="your">Your answer: <span>${yourTxt}</span></div>
        <div class="model">Correct: <span>${modelTxt}</span></div>
      </div>`;
    list.appendChild(li);
  });
  section.scrollIntoView({ behavior:'smooth' });
}
</script></body>
</html>
