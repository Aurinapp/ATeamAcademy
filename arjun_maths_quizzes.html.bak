    { q:"Relative frequency = times event occurred ÷ total trials.", type:"tf", answer:true, explain:"This is the experimental probability formula ✓" },
    { q:"More trials → closer relative frequency gets to theoretical probability.", type:"tf", answer:true, explain:"Law of Large Numbers ✓" },
    { q:"Median of 6, 2, 9, 14, 7, 1 = 6.5.", type:"tf", answer:true, explain:"Ordered: 1,2,6,7,9,14. Two middles: 6 and 7. Median=(6+7)/2=6.5 ✓" },
