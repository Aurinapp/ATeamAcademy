<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=Lexend:wght@300;400;500;600;700&display=swap" rel="stylesheet">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Arjun's Maths Quizzes</title>
<style>
  * { margin:0; padding:0; box-sizing:border-box; }
  :root {
    --blue:#1565c0; --teal:#0097a7; --teal2:#00bcd4;
    --light:#f0f7ff; --dark:#0a1f3c;
    --correct:#4caf50; --incorrect:#f44336;
  }
  body { font-family: 'Lexend', 'Segoe UI', sans-serif; background:var(--light); color:var(--dark); min-height:100vh; display:flex; flex-direction:column; 
  line-height: 1.7;

  word-spacing: 0.05em;

  font-size: 1rem;
}

  /* HEADER */
  header { background:linear-gradient(135deg,var(--blue),var(--teal)); color:white; padding:18px 28px; display:flex; align-items:center; justify-content:space-between; box-shadow:0 3px 12px rgba(21,101,192,.3); }
  .header-left { display:flex; align-items:center; gap:12px; }
  .back-btn { background:rgba(255,255,255,.2); border:none; color:white; border-radius:8px; padding:6px 12px; font-size:.85rem; cursor:pointer; text-decoration:none; display:inline-flex; align-items:center; gap:6px; transition:background .2s; }
  .back-btn:hover { background:rgba(255,255,255,.3); }
  header h1 { font-size:1.4rem; font-weight:700; }
  header h1 span { opacity:.8; font-weight:400; font-size:1rem; margin-left:8px; }
  .header-badge { background:rgba(255,255,255,.2); border-radius:20px; padding:6px 14px; font-size:.85rem; font-weight:600; }

  /* LAYOUT */
  .app { display:flex; flex:1; }

  /* SIDEBAR */
  nav.sidebar { width:260px; min-width:260px; background:var(--dark); color:white; padding:20px 0; overflow-y:auto; }
  .sidebar-title { padding:0 20px 14px; font-size:.75rem; text-transform:uppercase; letter-spacing:1.5px; color:rgba(255,255,255,.4); border-bottom:1px solid rgba(255,255,255,.08); margin-bottom:8px; }
  .topic-btn { display:flex; align-items:center; gap:10px; width:100%; padding:12px 20px; background:none; border:none; color:rgba(255,255,255,.7); text-align:left; cursor:pointer; font-size:.9rem; transition:all .2s; border-left:3px solid transparent; }
  .topic-btn:hover { background:rgba(255,255,255,.06); color:white; }
  .topic-btn.active { background:rgba(0,151,167,.18); color:white; border-left-color:var(--teal2); font-weight:600; }
  .topic-icon { font-size:1.1rem; width:24px; text-align:center; }
  .topic-count { margin-left:auto; background:rgba(255,255,255,.1); border-radius:10px; padding:2px 8px; font-size:.75rem; }

  /* MAIN */
  main { flex:1; padding:28px 32px; overflow-y:auto; display:flex; flex-direction:column; }

  /* SCREENS */
  .screen { display:none; }
  .screen.active { display:block; }

  /* HOME SCREEN */
  .home-hero {
    position:relative; overflow:hidden;
    background:linear-gradient(135deg,#1565c0,#00bcd4);
    border-radius:20px; padding:40px 36px; margin-bottom:28px; color:white;
  }
  .home-hero::before {
    content:'🔢'; position:absolute; right:28px; top:10px;
    font-size:6rem; opacity:.12; line-height:1; pointer-events:none;
  }
  .home-hero h2 { font-size:1.75rem; font-weight:800; margin-bottom:8px; }
  .home-hero p { opacity:.88; font-size:1rem; max-width:520px; line-height:1.6; }
  .home-stats { display:flex; gap:10px; margin-top:16px; flex-wrap:wrap; }
  .home-stat { background:rgba(255,255,255,.18); border-radius:10px; padding:6px 14px; font-size:.82rem; font-weight:600; }

  .topic-cards { display:grid; grid-template-columns:1fr 1fr; gap:14px; margin-bottom:20px; }
  .topic-card {
    background:white; border-radius:14px; padding:20px 22px;
    cursor:pointer; transition:all .2s;
    border:1.5px solid #d0e6f5;
    box-shadow:0 2px 10px rgba(21,101,192,.08);
  }
  .topic-card:hover { transform:translateY(-2px); box-shadow:0 6px 20px rgba(21,101,192,.14); border-color:var(--teal2); }
  .topic-card-icon { font-size:1.6rem; margin-bottom:8px; }
  .topic-card-title { font-size:1rem; font-weight:700; color:var(--dark); margin-bottom:4px; }
  .topic-card-meta { font-size:.8rem; color:#666; }
  .topic-card-meta span { color:var(--blue); font-weight:600; }

  .test-card {
    background:linear-gradient(135deg,#0097a7,#004d54);
    border-radius:14px; padding:20px 22px; cursor:pointer;
    transition:all .2s; color:white;
    box-shadow:0 4px 16px rgba(0,151,167,.3);
  }
  .test-card:hover { transform:translateY(-2px); box-shadow:0 8px 28px rgba(0,151,167,.4); }
  .test-card-icon { font-size:1.6rem; margin-bottom:8px; }
  .test-card-title { font-size:1rem; font-weight:700; margin-bottom:4px; }
  .test-card-meta { font-size:.8rem; opacity:.8; }
  .test-card-meta span { font-weight:600; opacity:1; }

  /* QUIZ SCREEN */
  .quiz-topic-header { margin-bottom:20px; }
  .quiz-topic-header h2 { font-size:1.5rem; font-weight:700; color:var(--blue); margin-bottom:4px; }
  .quiz-topic-header p { color:#555; font-size:.9rem; }

  .progress-bar-bg { background:#d0e6f5; border-radius:4px; height:8px; margin-bottom:18px; overflow:hidden; }
  .progress-bar-fill { height:100%; background:linear-gradient(90deg,var(--blue),var(--teal2)); border-radius:4px; transition:width .4s; }

  .question-box { background:white; border-radius:14px; padding:24px 26px; margin-bottom:20px; box-shadow:0 2px 12px rgba(21,101,192,.1); border:1.5px solid #d0e6f5; }
  .question-counter { font-size:.78rem; font-weight:700; color:var(--teal); text-transform:uppercase; letter-spacing:1px; margin-bottom:10px; }
  .question-text { font-size:1.1rem; font-weight:600; line-height:1.55; color:var(--dark); }

  .options { display:flex; flex-direction:column; gap:8px; margin-bottom:16px; }
  .option-btn {
    display:flex; align-items:center; gap:12px;
    padding:12px 16px; border-radius:10px;
    border:1.5px solid #d0e6f5; background:white;
    text-align:left; cursor:pointer; font-size:.92rem;
    transition:all .18s; color:var(--dark);
  }
  .option-btn:hover:not(:disabled) { border-color:var(--teal); background:#e0f7fa; }
  .option-btn.selected { border-color:var(--blue); background:#e3f2fd; }
  .option-btn.correct-ans { border-color:var(--correct); background:#e8f5e9; color:#1b5e20; }
  .option-btn.wrong-ans { border-color:var(--incorrect); background:#ffebee; color:#b71c1c; }
  .option-btn:disabled { cursor:default; }
  .opt-letter { font-weight:700; color:var(--blue); width:20px; text-align:center; flex-shrink:0; }

  .tf-row { display:flex; gap:12px; margin-bottom:16px; }
  .tf-btn { flex:1; padding:14px; border-radius:10px; border:1.5px solid #d0e6f5; background:white; font-size:1rem; font-weight:700; cursor:pointer; transition:all .18s; }
  .tf-btn.true-btn:hover:not(:disabled) { border-color:var(--correct); background:#e8f5e9; color:#1b5e20; }
  .tf-btn.false-btn:hover:not(:disabled) { border-color:var(--incorrect); background:#ffebee; color:#b71c1c; }
  .tf-btn.correct-ans { border-color:var(--correct); background:#e8f5e9; color:#1b5e20; }
  .tf-btn.wrong-ans { border-color:var(--incorrect); background:#ffebee; color:#b71c1c; }
  .tf-btn:disabled { cursor:default; }

  .feedback-box { display:none; padding:14px 16px; border-radius:10px; margin-bottom:16px; font-size:.9rem; line-height:1.6; }
  .feedback-box.show { display:block; }
  .feedback-box.correct { background:#e8f5e9; border-left:4px solid var(--correct); color:#1b5e20; }
  .feedback-box.incorrect { background:#ffebee; border-left:4px solid var(--incorrect); color:#b71c1c; }
  .feedback-box .fb-title { font-weight:700; margin-bottom:4px; }
  .feedback-box .fb-explain { color:#333; margin-top:6px; font-size:.88rem; }

  .quiz-nav { display:flex; gap:10px; }
  .nav-btn { padding:10px 22px; border-radius:10px; border:1.5px solid #d0e6f5; background:white; color:var(--dark); font-size:.9rem; font-weight:600; cursor:pointer; transition:all .18s; }
  .nav-btn:hover { background:#e3f2fd; border-color:var(--blue); }
  .nav-btn.primary { background:linear-gradient(135deg,var(--blue),var(--teal)); color:white; border-color:transparent; }
  .nav-btn.primary:hover { opacity:.9; }

  /* QUIZ RESULTS */
  .result-hero { text-align:center; background:linear-gradient(135deg,#e3f2fd,#e0f7fa); border-radius:20px; padding:40px; margin-bottom:24px; border:2px solid var(--teal2); }
  .result-emoji { font-size:4rem; margin-bottom:12px; }
  .result-score-big {
    font-size:3.5rem; font-weight:800; margin-bottom:6px;
    background:linear-gradient(135deg,var(--blue),var(--teal2));
    -webkit-background-clip:text; -webkit-text-fill-color:transparent; background-clip:text;
  }
  .result-label { font-size:1rem; color:#555; margin-bottom:10px; }
  .result-message { font-size:1.1rem; font-weight:600; color:var(--dark); }
  .result-actions { display:flex; gap:12px; justify-content:center; margin-top:20px; flex-wrap:wrap; }
  .result-btn { padding:11px 24px; border-radius:10px; font-size:.9rem; font-weight:600; cursor:pointer; transition:all .18s; border:1.5px solid; }
  .result-btn.primary { background:linear-gradient(135deg,var(--blue),var(--teal)); color:white; border-color:transparent; }
  .result-btn.secondary { background:white; color:var(--blue); border-color:#cde4f5; }
  .result-btn:hover { transform:translateY(-1px); }

  #quiz-retry-nudge { margin-top:10px; font-size:.88rem; color:var(--incorrect); font-weight:600; text-align:center; display:none; }
  #quiz-pass-actions { display:none; text-align:center; margin-top:8px; font-size:.88rem; color:var(--correct); font-weight:600; }

  .review-list { list-style:none; display:flex; flex-direction:column; gap:10px; }
  .review-item { padding:14px 16px; border-radius:10px; border:1.5px solid; }
  .review-item.correct { border-color:#c8e6c9; background:#f1f8f1; }
  .review-item.incorrect { border-color:#ffcdd2; background:#fff5f5; }
  .review-q { font-weight:600; font-size:.9rem; margin-bottom:8px; }
  .review-answer { display:flex; gap:16px; font-size:.82rem; }
  .review-answer .your { color:#555; }
  .review-answer .your span { color:var(--incorrect); font-weight:600; }
  .review-answer .model { color:#555; }
  .review-answer .model span { color:var(--correct); font-weight:600; }

  /* TEST SCREEN */
  .test-header { margin-bottom:20px; }
  .test-header h2 { font-size:1.5rem; font-weight:700; color:var(--blue); margin-bottom:4px; }
  .test-header p { color:#555; font-size:.9rem; }
  .test-question-block { background:white; border-radius:12px; padding:20px 22px; margin-bottom:14px; border:1.5px solid #d0e6f5; box-shadow:0 2px 8px rgba(21,101,192,.07); }
  .test-q-num { font-size:.75rem; text-transform:uppercase; font-weight:700; color:var(--teal); letter-spacing:1px; margin-bottom:8px; }
  .test-q-text { font-size:1rem; font-weight:600; margin-bottom:14px; line-height:1.5; }
  .test-options { display:flex; flex-direction:column; gap:7px; }
  .test-option { display:flex; align-items:center; gap:10px; padding:10px 14px; border-radius:9px; border:1.5px solid #d0e6f5; background:white; cursor:pointer; font-size:.88rem; transition:all .15s; }
  .test-option:hover:not(.disabled) { border-color:var(--teal); background:#e0f7fa; }
  .test-option.selected { border-color:var(--blue); background:#e3f2fd; }
  .test-option.correct-ans { border-color:var(--correct); background:#e8f5e9; }
  .test-option.wrong-ans { border-color:var(--incorrect); background:#ffebee; }
  .test-option.disabled { cursor:default; }
  .test-opt-letter { font-weight:700; color:var(--blue); width:18px; }
  .test-tf-row { display:flex; gap:10px; }
  .test-tf-btn { flex:1; padding:10px; border-radius:9px; border:1.5px solid #d0e6f5; background:white; font-weight:700; cursor:pointer; font-size:.9rem; transition:all .15s; }
  .test-tf-btn.selected { border-color:var(--blue); background:#e3f2fd; }
  .test-tf-btn.correct-ans { border-color:var(--correct); background:#e8f5e9; }
  .test-tf-btn.wrong-ans { border-color:var(--incorrect); background:#ffebee; }

  .submit-btn { display:block; width:100%; padding:16px; border-radius:12px; border:none; background:linear-gradient(135deg,var(--blue),var(--teal)); color:white; font-size:1.1rem; font-weight:700; cursor:pointer; transition:all .2s; margin-top:16px; }
  .submit-btn:hover { opacity:.9; transform:translateY(-1px); }

  /* TEST RESULTS */
  .test-result-hero { text-align:center; background:linear-gradient(135deg,#e3f2fd,#e0f7fa); border-radius:20px; padding:40px; margin-bottom:24px; border:2px solid var(--teal2); }
  .test-score-grid { display:grid; grid-template-columns:repeat(3,1fr); gap:12px; margin-top:24px; }
  .test-score-cell { background:white; border-radius:12px; padding:14px; text-align:center; box-shadow:0 2px 8px rgba(21,101,192,.1); }
  .test-score-cell .num { font-size:2rem; font-weight:800; background:linear-gradient(135deg,var(--blue),var(--teal2)); -webkit-background-clip:text; -webkit-text-fill-color:transparent; background-clip:text; }
  .test-score-cell .lbl { font-size:.78rem; color:#777; text-transform:uppercase; letter-spacing:.5px; }
  .test-result-actions { display:flex; gap:12px; justify-content:center; margin-top:24px; flex-wrap:wrap; }


  /* ── A11Y TOOLBAR ── */
  #a11y-toolbar{position:fixed!important;bottom:24px!important;right:24px!important;z-index:2147483647!important;font-family:'Lexend','Segoe UI',sans-serif;}
  #a11y-fab{width:50px;height:50px;border-radius:50%;background:#1565c0;border:none;color:#fff;font-size:1.3rem;cursor:pointer;box-shadow:0 4px 18px rgba(0,0,0,.35);display:flex;align-items:center;justify-content:center;transition:transform .2s,background .2s;}
  #a11y-fab:hover{background:#0d47a1;transform:scale(1.07);}
  #a11y-fab.open{background:#0d47a1;}
  #a11y-panel{position:absolute;bottom:62px;right:0;background:#fff;border-radius:16px;box-shadow:0 8px 32px rgba(0,0,0,.2);padding:16px;width:260px;border:1px solid rgba(0,0,0,.07);}
  #a11y-panel[hidden]{display:none!important;}
  .a11y-title{font-size:.7rem;font-weight:700;text-transform:uppercase;letter-spacing:1px;color:#888;margin-bottom:12px;}
  .a11y-action-btn{display:flex;align-items:center;gap:10px;width:100%;padding:10px 12px;border-radius:10px;background:#f0f7ff;border:1.5px solid #cde4f5;color:#1565c0;font-size:.9rem;font-weight:600;cursor:pointer;font-family:inherit;}
  .a11y-action-btn.a11y-stop{background:#fee2e2;border-color:#fca5a5;color:#dc2626;}
  .a11y-divider{height:1px;background:#e5e7eb;margin:12px 0;}
  .a11y-row{display:flex;align-items:center;justify-content:space-between;margin-bottom:10px;}
  .a11y-col-row{flex-direction:column;align-items:flex-start;gap:8px;margin-bottom:4px;}
  .a11y-label{font-size:.85rem;color:#222;font-weight:500;}
  .a11y-pill{padding:4px 14px;border-radius:20px;border:2px solid #d1d5db;background:#f3f4f6;color:#6b7280;font-size:.78rem;font-weight:700;cursor:pointer;font-family:inherit;}
  .a11y-pill.on{background:#1565c0;border-color:#1565c0;color:#fff;}
  #a11y-colours{display:flex;gap:7px;flex-wrap:wrap;}
  .a11y-col-chip{width:28px;height:28px;border-radius:50%;border:2.5px solid #d1d5db;cursor:pointer;font-size:.65rem;display:flex;align-items:center;justify-content:center;background:#e5e7eb;}
  .a11y-col-chip.sel{border-color:#1565c0;border-width:3px;}
  #a11y-overlay{position:fixed!important;inset:0;pointer-events:none;z-index:2147483646!important;transition:background .35s;}
  b.bionic-b{font-weight:800;}
  .a11y-stepper{display:flex;gap:4px;}
  .a11y-step-btn{width:32px;height:28px;border-radius:8px;border:2px solid #d1d5db;background:#f3f4f6;color:#6b7280;font-size:.82rem;font-weight:700;cursor:pointer;display:flex;align-items:center;justify-content:center;font-family:inherit;transition:background .15s,border-color .15s;}
  .a11y-step-btn.on{background:#1565c0;border-color:#1565c0;color:#fff;}
  #a11y-ruler-line{position:fixed!important;left:0;right:0;height:34px;pointer-events:none;z-index:2147483645!important;background:rgba(21,101,192,.1);border-top:2px solid rgba(21,101,192,.35);border-bottom:2px solid rgba(21,101,192,.35);display:none;top:0;}
  body.ruler-on #a11y-ruler-line{display:block;}
  body.opendyslexic,body.opendyslexic *{font-family:'OpenDyslexic','Lexend','Segoe UI',sans-serif!important;}

</style>
</head>
<body>
<div id="a11y-toolbar"><button id="a11y-fab" title="Accessibility tools" aria-label="Accessibility tools">&#9681;</button><div id="a11y-panel" hidden><div class="a11y-title">Accessibility</div><button id="a11y-tts" class="a11y-action-btn"><span id="a11y-tts-icon">&#128266;</span><span id="a11y-tts-label"> Read aloud</span></button><div class="a11y-divider"></div><div class="a11y-row"><span class="a11y-label">Bionic reading</span><button id="a11y-bionic" class="a11y-pill">Off</button></div><div class="a11y-row"><span class="a11y-label">OpenDyslexic font</span><button id="a11y-od" class="a11y-pill">Off</button></div><div class="a11y-row"><span class="a11y-label">Reading ruler</span><button id="a11y-ruler-btn" class="a11y-pill">Off</button></div><div class="a11y-divider"></div><div class="a11y-row"><span class="a11y-label">Text size</span><div class="a11y-stepper"><button class="a11y-step-btn on" id="a11y-sz1" title="Normal">A</button><button class="a11y-step-btn" id="a11y-sz2" title="Large">A+</button><button class="a11y-step-btn" id="a11y-sz3" title="XL">A++</button></div></div><div class="a11y-row"><span class="a11y-label">Line spacing</span><div class="a11y-stepper"><button class="a11y-step-btn on" id="a11y-ls1" title="Normal">1&#215;</button><button class="a11y-step-btn" id="a11y-ls2" title="Relaxed">1.5&#215;</button><button class="a11y-step-btn" id="a11y-ls3" title="Wide">2&#215;</button></div></div><div class="a11y-divider"></div><div class="a11y-row a11y-col-row"><span class="a11y-label">Colour overlay</span><div id="a11y-colours"><button class="a11y-col-chip sel" data-col="none" title="None">&#x2715;</button><button class="a11y-col-chip" data-col="cream" style="background:#fdf6e3" title="Cream"></button><button class="a11y-col-chip" data-col="yellow" style="background:#fff9c4" title="Yellow"></button><button class="a11y-col-chip" data-col="blue" style="background:#dbeafe" title="Blue"></button><button class="a11y-col-chip" data-col="green" style="background:#dcfce7" title="Green"></button><button class="a11y-col-chip" data-col="peach" style="background:#fce7f3" title="Peach"></button></div></div></div></div><div id="a11y-overlay"></div><div id="a11y-ruler-line"></div>


<header>
  <div class="header-left">
    <a class="back-btn" href="index.html">← Back</a>
    <h1>📝 Arjun's Quizzes &amp; Tests <span>Maths · KS3 Year 8</span></h1>
  </div>
  <div class="header-badge">Year 8</div>
</header>

<div class="app">
  <nav class="sidebar">
    <div class="sidebar-title">Topics</div>
    <button class="topic-btn" onclick="showHome()" id="sideHome">
      <span class="topic-icon">🏠</span> Home
    </button>
    <button class="topic-btn" onclick="startQuiz(0)" id="topicBtn0">
      <span class="topic-icon">🔢</span> Number
      <span class="topic-count">30</span>
    </button>
    <button class="topic-btn" onclick="startQuiz(1)" id="topicBtn1">
      <span class="topic-icon">🔣</span> Algebra
      <span class="topic-count">30</span>
    </button>
    <button class="topic-btn" onclick="startQuiz(2)" id="topicBtn2">
      <span class="topic-icon">📐</span> Geometry &amp; Measures
      <span class="topic-count">30</span>
    </button>
    <button class="topic-btn" onclick="startQuiz(3)" id="topicBtn3">
      <span class="topic-icon">⚖️</span> Ratio &amp; Proportion
      <span class="topic-count">30</span>
    </button>
    <button class="topic-btn" onclick="startQuiz(4)" id="topicBtn4">
      <span class="topic-icon">📊</span> Statistics &amp; Probability
      <span class="topic-count">30</span>
    </button>
    <button class="topic-btn" onclick="startTest()" id="topicBtnTest" style="margin-top:8px;border-top:1px solid rgba(255,255,255,.1);padding-top:16px;">
      <span class="topic-icon">🏆</span> Full Test
      <span class="topic-count">50</span>
    </button>
  </nav>

  <main>

    <!-- HOME -->
    <div class="screen active" id="screenHome">
      <div class="home-hero">
        <h2>📝 Maths Quizzes &amp; Tests</h2>
        <p>Practice with quizzes for each topic, then tackle the full 50-question test. You need 80% to pass — get to work, Arjun!</p>
        <div class="home-stats">
          <div class="home-stat">📚 5 Topics</div>
          <div class="home-stat">❓ 150 Quiz Questions</div>
          <div class="home-stat">🏆 50-Question Test</div>
        </div>
      </div>
      <div class="topic-cards">
        <div class="topic-card" onclick="startQuiz(0)">
          <div class="topic-card-icon">🔢</div>
          <div class="topic-card-title">Number</div>
          <div class="topic-card-meta"><span>30 questions</span> · Primes, fractions, percentages, indices</div>
        </div>
        <div class="topic-card" onclick="startQuiz(1)">
          <div class="topic-card-icon">🔣</div>
          <div class="topic-card-title">Algebra</div>
          <div class="topic-card-meta"><span>30 questions</span> · Expressions, equations, sequences, graphs</div>
        </div>
        <div class="topic-card" onclick="startQuiz(2)">
          <div class="topic-card-icon">📐</div>
          <div class="topic-card-title">Geometry &amp; Measures</div>
          <div class="topic-card-meta"><span>30 questions</span> · Angles, area, volume, transformations</div>
        </div>
        <div class="topic-card" onclick="startQuiz(3)">
          <div class="topic-card-icon">⚖️</div>
          <div class="topic-card-title">Ratio &amp; Proportion</div>
          <div class="topic-card-meta"><span>30 questions</span> · Ratios, proportion, speed/distance/time</div>
        </div>
        <div class="topic-card" onclick="startQuiz(4)">
          <div class="topic-card-icon">📊</div>
          <div class="topic-card-title">Statistics &amp; Probability</div>
          <div class="topic-card-meta"><span>30 questions</span> · Averages, charts, probability</div>
        </div>
        <div class="test-card" onclick="startTest()">
          <div class="test-card-icon">🏆</div>
          <div class="test-card-title">Full Maths Test</div>
          <div class="test-card-meta"><span>50 questions</span> · All topics · 80% to pass</div>
        </div>
      </div>
    </div>

    <!-- QUIZ -->
    <div class="screen" id="screenQuiz">
      <div class="quiz-topic-header">
        <h2 id="quizTopicTitle"></h2>
        <p id="quizTopicDesc"></p>
      </div>
      <div class="progress-bar-bg">
        <div class="progress-bar-fill" id="quizProgressFill" style="width:0%"></div>
      </div>
      <div class="question-box">
        <div class="question-counter" id="questionCounter">Question 1 of 30</div>
        <div class="question-text" id="questionText"></div>
      </div>
      <div id="answerArea"></div>
      <div class="feedback-box" id="feedbackBox">
        <div class="fb-title" id="fbTitle"></div>
        <div class="fb-explain" id="fbExplain"></div>
      </div>
      <div class="quiz-nav">
        <button class="nav-btn" onclick="showHome()">← Home</button>
        <button class="nav-btn primary" id="nextBtn" onclick="nextQuestion()" style="display:none">Next →</button>
      </div>
    </div>

    <!-- QUIZ RESULT -->
    <div class="screen" id="screenResult">
      <div class="result-hero">
        <div class="result-emoji" id="resultEmoji">🎉</div>
        <div class="result-score-big" id="resultScore">0%</div>
        <div class="result-label" id="resultLabel">0 out of 30 correct</div>
        <div class="result-message" id="resultMessage"></div>
      </div>
      <p id="quiz-retry-nudge">Looks like you need to do this again, bucko.</p>
      <p id="quiz-pass-actions">Well done — you can move on to the next topic! 🌟</p>
      <div class="result-actions">
        <button class="result-btn primary" onclick="retryQuiz()">🔁 Try Again</button>
        <button class="result-btn secondary" onclick="showReview()">📋 Review Answers</button>
        <button class="result-btn secondary" onclick="showHome()">🏠 Home</button>
      </div>
      <div id="reviewSection" style="display:none;margin-top:28px;">
        <h3 style="margin-bottom:14px;font-size:1.1rem;color:var(--blue);">Answer Review</h3>
        <ul class="review-list" id="reviewList"></ul>
      </div>
    </div>

    <!-- TEST -->
    <div class="screen" id="screenTest">
      <div class="test-header">
        <h2>🏆 Full Maths Test</h2>
        <p>50 questions across all topics — complete all questions then submit. You need 80% (40/50) to pass.</p>
      </div>
      <div id="test-body"></div>
      <button class="submit-btn" id="submitBtn" onclick="submitTest()">Submit Test ✓</button>
    </div>

    <!-- TEST RESULT -->
    <div class="screen" id="screenTestResult">
      <div class="test-result-hero">
        <div class="result-emoji" id="testResultEmoji">🏆</div>
        <div class="result-score-big" id="testResultScore">0%</div>
        <div style="font-size:1.1rem;font-weight:600;margin-top:4px;" id="testResultMsg"></div>
        <div class="test-score-grid">
          <div class="test-score-cell"><div class="num" id="tcCorrect">0</div><div class="lbl">Correct</div></div>
          <div class="test-score-cell"><div class="num" id="tcIncorrect">0</div><div class="lbl">Wrong</div></div>
          <div class="test-score-cell"><div class="num" id="tcPercent">0%</div><div class="lbl">Score</div></div>
        </div>
      </div>
      <p id="test-retry-nudge" style="display:none;text-align:center;color:var(--incorrect);font-weight:600;font-size:.9rem;margin-bottom:16px;">Looks like you need to do this again, bucko.</p>
      <div class="test-result-actions">
        <button class="result-btn primary" onclick="startTest()">🔁 Retry Test</button>
        <button class="result-btn secondary" onclick="showTestReview()">📋 Review Answers</button>
        <button class="result-btn secondary" onclick="showHome()">🏠 Home</button>
      </div>
      <div id="testReviewSection" style="display:none;margin-top:28px;">
        <h3 style="margin-bottom:14px;font-size:1.1rem;color:var(--blue);">Test Answer Review</h3>
        <ul class="review-list" id="testReviewList"></ul>
      </div>
    </div>

  </main>
</div>

<script>
(function(){
var S='ateam_a11y',st={bionic:false,overlay:'none',od:false,ruler:false,sz:1,ls:1};
try{Object.assign(st,JSON.parse(localStorage.getItem(S)||'{}'));}catch(e){}
var fab,panel,ttsBtn,ttsIcon,ttsLbl,bioBtn,ovl,ttsOn=false;
function init(){
  fab=document.getElementById('a11y-fab');
  panel=document.getElementById('a11y-panel');
  ttsBtn=document.getElementById('a11y-tts');
  ttsIcon=document.getElementById('a11y-tts-icon');
  ttsLbl=document.getElementById('a11y-tts-label');
  bioBtn=document.getElementById('a11y-bionic');
  ovl=document.getElementById('a11y-overlay');
  if(!fab)return;
  var OV={none:'transparent',cream:'rgba(253,246,227,.5)',yellow:'rgba(255,249,196,.5)',blue:'rgba(219,234,254,.5)',green:'rgba(220,252,231,.5)',peach:'rgba(252,231,243,.5)'};
  fab.addEventListener('click',function(e){e.stopPropagation();var o=panel.hasAttribute('hidden');if(o)panel.removeAttribute('hidden');else panel.setAttribute('hidden','');fab.classList.toggle('open',o);});
  document.addEventListener('click',function(e){var tb=document.getElementById('a11y-toolbar');if(tb&&!tb.contains(e.target))panel.setAttribute('hidden','');});
  var ttsOn=false;
  function getText(){var fc=document.getElementById('flashcard');if(fc){var id=fc.classList.contains('flipped')?'cardAnswer':'cardQuestion';var el=document.getElementById(id);if(el&&el.innerText.trim())return el.innerText.trim();}var q=document.querySelector('.screen.active .q-text');if(q)return q.innerText.trim();var ns=document.querySelectorAll('.notes-section.open .notes-section-body');if(ns.length)return Array.from(ns).map(function(n){return n.innerText.trim();}).join('\n\n');var m=document.querySelector('main')||document.querySelector('.screen.active');return m?m.innerText.trim().slice(0,2500):'';}
  function startTTS(){window.speechSynthesis.cancel();var t=getText();if(!t)return;var u=new SpeechSynthesisUtterance(t);u.rate=0.88;u.onend=u.onerror=function(){setTS(false);};window.speechSynthesis.speak(u);setTS(true);}
  function stopTTS(){window.speechSynthesis.cancel();setTS(false);}
  function setTS(on){ttsOn=on;ttsBtn.classList.toggle('a11y-stop',on);ttsIcon.innerHTML=on?'&#9209;':'&#128266;';ttsLbl.textContent=on?' Stop':' Read aloud';}
  ttsBtn.addEventListener('click',function(){ttsOn?stopTTS():startTTS();});
  function bioW(w){if(w.length<=2)return w;var h=Math.ceil(w.length/2);return '<b class="bionic-b">'+w.slice(0,h)+'</b>'+w.slice(h);}
  function walkBold(node){if(node.nodeType===3){var t=node.textContent;if(!t.trim())return;var html=t.replace(/([A-Za-zÀ-ɏ]{2,})/g,function(w){return bioW(w);});if(html===t)return;var s=document.createElement('span');s.innerHTML=html;node.parentNode.replaceChild(s,node);}else if(node.nodeType===1&&!/^(SCRIPT|STYLE|B|BUTTON|INPUT)$/.test(node.tagName))Array.from(node.childNodes).forEach(walkBold);}
  var TG='#cardQuestion,#cardAnswer,.q-text,.option-btn,.notes-section-body,.card-text,.home-hero p';
  function applyBio(){document.querySelectorAll(TG).forEach(function(el){if(el.dataset.bd)return;el.dataset.bd='1';el.dataset.bo=el.innerHTML;walkBold(el);});}
  function removeBio(){document.querySelectorAll('[data-bd]').forEach(function(el){el.innerHTML=el.dataset.bo||el.innerHTML;delete el.dataset.bd;delete el.dataset.bo;});}
  ['flipCard','loadQuestion','showQuestion','nextCard','prevCard'].forEach(function(fn){if(typeof window[fn]==='function'){var o=window[fn];window[fn]=function(){var r=o.apply(this,arguments);if(st.bionic)setTimeout(applyBio,80);return r;};}});
  var bt;new MutationObserver(function(){if(!st.bionic)return;clearTimeout(bt);bt=setTimeout(applyBio,80);}).observe(document.body,{childList:true,subtree:true});
  function setBio(on){st.bionic=on;bioBtn.textContent=on?'On':'Off';bioBtn.classList.toggle('on',on);if(on)applyBio();else removeBio();save();}
  bioBtn.addEventListener('click',function(){setBio(!st.bionic);});
  function setOvl(col){st.overlay=col;ovl.style.background=OV[col]||'transparent';document.querySelectorAll('.a11y-col-chip').forEach(function(c){c.classList.toggle('sel',c.dataset.col===col);});save();}
  document.querySelectorAll('.a11y-col-chip').forEach(function(btn){btn.addEventListener('click',function(){setOvl(btn.dataset.col);});});
  // OpenDyslexic font
  var odBtn=document.getElementById('a11y-od');
  function setOD(on){st.od=on;document.body.classList.toggle('opendyslexic',on);if(on&&!document.getElementById('od-font')){var l=document.createElement('link');l.id='od-font';l.rel='stylesheet';l.href='https://fonts.cdnfonts.com/css/opendyslexic';document.head.appendChild(l);}if(odBtn){odBtn.textContent=on?'On':'Off';odBtn.classList.toggle('on',on);}save();}
  if(odBtn)odBtn.addEventListener('click',function(){setOD(!st.od);});
  // Reading ruler
  var rulerEl=document.getElementById('a11y-ruler-line'),rulerBtn=document.getElementById('a11y-ruler-btn');
  function setRuler(on){st.ruler=on;document.body.classList.toggle('ruler-on',on);if(rulerBtn){rulerBtn.textContent=on?'On':'Off';rulerBtn.classList.toggle('on',on);}save();}
  document.addEventListener('mousemove',function(e){if(st.ruler&&rulerEl)rulerEl.style.top=(e.clientY-17)+'px';});
  if(rulerBtn)rulerBtn.addEventListener('click',function(){setRuler(!st.ruler);});
  // Text size (3 steps: 100% / 118% / 136%)
  var SZ=[1,1.18,1.36],szBtns=[document.getElementById('a11y-sz1'),document.getElementById('a11y-sz2'),document.getElementById('a11y-sz3')];
  function setSz(i){st.sz=i;document.documentElement.style.fontSize=(SZ[i-1]*16)+'px';szBtns.forEach(function(b,idx){if(b)b.classList.toggle('on',idx+1===i);});save();}
  szBtns.forEach(function(b,i){if(b)b.addEventListener('click',function(){setSz(i+1);});});
  // Line spacing (3 steps: 1.7 / 2.1 / 2.6)
  var LS=[1.7,2.1,2.6],lsBtns=[document.getElementById('a11y-ls1'),document.getElementById('a11y-ls2'),document.getElementById('a11y-ls3')];
  function setLs(i){st.ls=i;document.body.style.lineHeight=LS[i-1];lsBtns.forEach(function(b,idx){if(b)b.classList.toggle('on',idx+1===i);});save();}
  lsBtns.forEach(function(b,i){if(b)b.addEventListener('click',function(){setLs(i+1);});});
  // Save & restore all settings
  function save(){try{localStorage.setItem(S,JSON.stringify({bionic:st.bionic,overlay:st.overlay,od:st.od,ruler:st.ruler,sz:st.sz,ls:st.ls}));}catch(e){}}
  setOvl(st.overlay);if(st.bionic)setBio(true);setOD(!!st.od);setRuler(!!st.ruler);setSz(st.sz||1);setLs(st.ls||1);
}
if(document.readyState==='loading')document.addEventListener('DOMContentLoaded',init);else init();
})();
</script>
<script>
// ============================================================
// QUIZ DATA — 30 questions per topic, mixed MCQ + True/False
// ============================================================
const quizData = [

  // TOPIC 0: NUMBER
  [
    { q:"Which of these is a prime number?", type:"mcq", options:["9","15","17","21"], answer:2, explain:"17 has exactly two factors: 1 and itself. 9=3², 15=3×5, 21=3×7." },
    { q:"60 written as a product of prime factors is 2² × 3 × 5.", type:"tf", answer:true, explain:"60 = 4×15 = 2²×3×5 ✓" },
    { q:"What is the HCF of 24 and 36?", type:"mcq", options:["6","8","12","18"], answer:2, explain:"24=2³×3, 36=2²×3². HCF=2²×3=12." },
    { q:"What is the LCM of 4 and 6?", type:"mcq", options:["2","12","24","48"], answer:1, explain:"4=2², 6=2×3. LCM=2²×3=12." },
    { q:"1 is a prime number.", type:"tf", answer:false, explain:"A prime has exactly 2 factors. 1 only has one factor — itself. So 1 is NOT prime." },
    { q:"What is ¾ + ⅝?", type:"mcq", options:["8/12","11/8","11/12","6/7"], answer:1, explain:"Common denominator 8: 6/8+5/8=11/8." },
    { q:"2/3 × 3/4 = 1/2", type:"tf", answer:true, explain:"2×3=6, 3×4=12. 6/12=1/2 ✓" },
    { q:"Calculate: 2/3 ÷ 1/4", type:"mcq", options:["1/6","8/3","2/12","3/2"], answer:1, explain:"Keep Change Flip: 2/3 × 4/1 = 8/3." },
    { q:"5/8 as a percentage is 62.5%.", type:"tf", answer:true, explain:"5÷8=0.625. ×100=62.5% ✓" },
    { q:"What is 15% of £240?", type:"mcq", options:["£24","£30","£36","£40"], answer:2, explain:"10%=£24, 5%=£12. 15%=£36." },
    { q:"What is 5²?", type:"mcq", options:["10","20","25","50"], answer:2, explain:"5²=5×5=25." },
    { q:"√144 = 12", type:"tf", answer:true, explain:"12×12=144 ✓" },
    { q:"x³ × x⁴ = x⁷", type:"tf", answer:true, explain:"Add the indices: 3+4=7 ✓" },
    { q:"(–5) × (–3) = –15", type:"tf", answer:false, explain:"Negative × Negative = Positive. (–5)×(–3)=+15." },
    { q:"Round 4.8653 to 2 decimal places.", type:"mcq", options:["4.86","4.87","4.9","4.865"], answer:1, explain:"3rd decimal is 5 ≥ 5, so round up: 4.87." },
    { q:"Round 0.006783 to 2 significant figures.", type:"mcq", options:["0.0068","0.007","0.00678","0.0067"], answer:0, explain:"First sig fig=6, second=7. Third digit=8≥5, round up: 0.0068." },
    { q:"An estimate for 49.2 × 19.7 is 1000.", type:"tf", answer:true, explain:"50×20=1000 ✓" },
    { q:"The multiplier for a 35% increase is 1.35.", type:"tf", answer:true, explain:"1 + 0.35 = 1.35 ✓" },
    { q:"A coat costs £120. A 25% reduction gives a new price of £90.", type:"tf", answer:true, explain:"£120×0.75=£90 ✓" },
    { q:"What is the reciprocal of 5?", type:"mcq", options:["–5","5","1/5","1/25"], answer:2, explain:"Reciprocal of 5 = 1/5." },
    { q:"x⁵ ÷ x² = x³", type:"tf", answer:true, explain:"Subtract indices: 5–2=3 ✓" },
    { q:"0.27 is greater than 0.3.", type:"tf", answer:false, explain:"0.27=0.270 < 0.300. So 0.27 < 0.3." },
    { q:"What is 2³?", type:"mcq", options:["6","8","16","32"], answer:1, explain:"2³=2×2×2=8." },
    { q:"7/20 as a percentage is 35%.", type:"tf", answer:true, explain:"7÷20=0.35. ×100=35% ✓" },
    { q:"The HCF is always ≥ the LCM of two numbers.", type:"tf", answer:false, explain:"LCM is always ≥ HCF. E.g. HCF(4,6)=2, LCM=12." },
    { q:"What is the percentage change from £80 to £100?", type:"mcq", options:["20%","25%","15%","80%"], answer:1, explain:"Change=£20. (20/80)×100=25%." },
    { q:"(3²)² = 3⁴", type:"tf", answer:true, explain:"(xᵐ)ⁿ=xᵐⁿ. (3²)²=3⁴ ✓" },
    { q:"Any number to the power of 0 equals 0.", type:"tf", answer:false, explain:"Any non-zero number to the power 0 = 1. E.g. 5⁰=1." },
    { q:"What is the correct order (smallest to largest): 0.31, 0.3, 0.305?", type:"mcq", options:["0.31,0.305,0.3","0.3,0.31,0.305","0.3,0.305,0.31","0.305,0.3,0.31"], answer:2, explain:"0.300 < 0.305 < 0.310." },
    { q:"3/8 as a decimal is 0.375.", type:"tf", answer:true, explain:"3÷8=0.375 ✓" }
  ],

  // TOPIC 1: ALGEBRA
  [
    { q:"Simplify: 5x + 3y − 2x + y", type:"mcq", options:["3x + 4y","7x + 4y","3x + 2y","7x + 2y"], answer:0, explain:"(5x−2x)+(3y+y)=3x+4y." },
    { q:"4(3x − 2) = 12x − 8", type:"tf", answer:true, explain:"4×3x=12x, 4×(−2)=−8 ✓" },
    { q:"Factorise: 15x + 10", type:"mcq", options:["3(5x+2)","5(3x+2)","5(3x+10)","15(x+10)"], answer:1, explain:"HCF=5. 5(3x+2)." },
    { q:"Substituting x=4 into 3x²−2x+5 gives 45.", type:"tf", answer:true, explain:"3(16)−2(4)+5=48−8+5=45 ✓" },
    { q:"Solve: 3x + 5 = 20", type:"mcq", options:["x=4","x=5","x=6","x=8"], answer:1, explain:"3x=15. x=5." },
    { q:"Solve: 5x − 3 = 2x + 9", type:"mcq", options:["x=2","x=3","x=4","x=6"], answer:2, explain:"3x=12. x=4." },
    { q:"The sequence 2, 7, 12, 17… has a common difference of 5.", type:"tf", answer:true, explain:"7−2=5, 12−7=5 ✓" },
    { q:"The nth term of 4, 7, 10, 13… is 3n + 1.", type:"tf", answer:true, explain:"d=3. n=1: 3(1)+1=4 ✓" },
    { q:"Using nth term = 5n − 2, the 10th term is 48.", type:"tf", answer:true, explain:"5(10)−2=48 ✓" },
    { q:"In y = 3x − 4, the gradient is 3 and y-intercept is −4.", type:"tf", answer:true, explain:"m=3, c=−4 in y=mx+c ✓" },
    { q:"What is the gradient of y = −2x + 7?", type:"mcq", options:["2","7","−2","−7"], answer:2, explain:"Gradient = coefficient of x = −2." },
    { q:"2(x+4)+3(x−1) = 5x+10", type:"tf", answer:false, explain:"2x+8+3x−3=5x+5, not 5x+10." },
    { q:"The solution to 4x − 1 > 11 is x > 3.", type:"tf", answer:true, explain:"4x>12. x>3 ✓" },
    { q:"Factorise completely: 8x² + 12x", type:"mcq", options:["2x(4x+6)","4x(2x+3)","8x(x+4)","4(2x²+3x)"], answer:1, explain:"HCF=4x. 4x(2x+3)." },
    { q:"The 15th term of 3n − 1 is 44.", type:"tf", answer:true, explain:"3(15)−1=44 ✓" },
    { q:"The y-intercept of y = 5x + 3 is 3.", type:"tf", answer:true, explain:"When x=0: y=3 ✓" },
    { q:"If x = −2, what is 4x + 7?", type:"mcq", options:["−1","−15","1","15"], answer:0, explain:"4(−2)+7=−8+7=−1." },
    { q:"x⁴ × x³ ÷ x² = x⁵", type:"tf", answer:true, explain:"x⁷÷x²=x⁵ ✓" },
    { q:"An equation must have an equals sign.", type:"tf", answer:true, explain:"A = sign distinguishes an equation from an expression ✓" },
    { q:"What is the gradient between (2,3) and (6,11)?", type:"mcq", options:["2","3","4","8"], answer:0, explain:"(11−3)/(6−2)=8/4=2." },
    { q:"Solve: 2(x + 3) = 14", type:"mcq", options:["x=4","x=5","x=6","x=8"], answer:0, explain:"2x+6=14. 2x=8. x=4." },
    { q:"The sequence 1, 4, 9, 16, 25… is an arithmetic sequence.", type:"tf", answer:false, explain:"Differences are 3,5,7,9 — not constant. These are square numbers, not arithmetic." },
    { q:"The nth term of 7, 10, 13, 16… is 3n + 4.", type:"tf", answer:true, explain:"d=3. n=1: 3+4=7 ✓" },
    { q:"What is 2x² when x = 3?", type:"mcq", options:["12","18","36","6"], answer:1, explain:"2×3²=2×9=18." },
    { q:"y = mx + c represents a straight line.", type:"tf", answer:true, explain:"y=mx+c is the standard form of a straight-line equation ✓" },
    { q:"Is x = 7 the solution to 2x − 3 = 11?", type:"tf", answer:true, explain:"2(7)−3=11 ✓" },
    { q:"Expand: (x + 3)(x + 2) = x² + 5x + 6", type:"tf", answer:true, explain:"x²+2x+3x+6=x²+5x+6 ✓" },
    { q:"Solve: x/3 + 4 = 7", type:"mcq", options:["x=1","x=3","x=9","x=33"], answer:2, explain:"x/3=3. x=9." },
    { q:"Solve: 3(2x − 1) = 15 gives x = 3.", type:"tf", answer:true, explain:"6x−3=15. 6x=18. x=3 ✓" },
    { q:"In y = 4x − 7, when x = 2, y = 1.", type:"tf", answer:true, explain:"4(2)−7=1 ✓" }
  ],

  // TOPIC 2: GEOMETRY & MEASURES
  [
    { q:"Angles on a straight line add up to 180°.", type:"tf", answer:true, explain:"Fundamental angle fact ✓" },
    { q:"What do angles in a triangle add up to?", type:"mcq", options:["90°","180°","270°","360°"], answer:1, explain:"Triangle angle sum = 180°." },
    { q:"Angles in a quadrilateral add up to 360°.", type:"tf", answer:true, explain:"(4−2)×180°=360° ✓" },
    { q:"Alternate angles between parallel lines are equal.", type:"tf", answer:true, explain:"Z-angles are equal ✓" },
    { q:"Co-interior angles between parallel lines add up to 360°.", type:"tf", answer:false, explain:"Co-interior (C) angles add to 180°, not 360°." },
    { q:"What is the sum of interior angles in a pentagon?", type:"mcq", options:["360°","450°","540°","720°"], answer:2, explain:"(5−2)×180°=540°." },
    { q:"The sum of interior angles in a hexagon is 720°.", type:"tf", answer:true, explain:"(6−2)×180°=720° ✓" },
    { q:"Area of a triangle with base 8 cm and height 5 cm = ?", type:"mcq", options:["40 cm²","20 cm²","13 cm²","80 cm²"], answer:1, explain:"½×8×5=20 cm²." },
    { q:"Area of a trapezium with parallel sides 6 cm and 10 cm, height 4 cm = 32 cm².", type:"tf", answer:true, explain:"½×(6+10)×4=32 cm² ✓" },
    { q:"Area of a circle with radius 5 cm ≈ 78.5 cm².", type:"tf", answer:true, explain:"π×5²≈78.5 cm² ✓" },
    { q:"Circumference = πd where d is the diameter.", type:"tf", answer:true, explain:"C=πd=2πr ✓" },
    { q:"Volume of a cuboid 4×3×5 cm = 60 cm³.", type:"tf", answer:true, explain:"4×3×5=60 cm³ ✓" },
    { q:"Volume of a triangular prism (triangle base 6, height 4, length 10) = 120 cm³.", type:"tf", answer:true, explain:"½×6×4×10=120 cm³ ✓" },
    { q:"A reflection preserves the size and shape of a shape.", type:"tf", answer:true, explain:"Reflection is a congruence transformation ✓" },
    { q:"Which info fully describes a rotation?", type:"mcq", options:["Mirror line","Scale factor and centre","Angle, direction and centre","Column vector"], answer:2, explain:"Rotation needs: angle, direction (CW/ACW), and centre." },
    { q:"A translation is described using a column vector.", type:"tf", answer:true, explain:"E.g. (3 above −2) = 3 right, 2 down ✓" },
